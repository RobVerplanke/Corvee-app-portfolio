
<div class="toolbar">

  <div class="toolbar-item">
    <button class="toolbar-btn" data-target="dropdown-overview">
      <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M555-435q-35-35-35-85t35-85q35-35 85-35t85 35q35 35 35 85t-35 85q-35 35-85 35t-85-35ZM400-160v-76q0-21 10-40t28-30q45-27 95.5-40.5T640-360q56 0 106.5 13.5T842-306q18 11 28 30t10 40v76H400Zm86-80h308q-35-20-74-30t-80-10q-41 0-80 10t-74 30Zm182.5-251.5Q680-503 680-520t-11.5-28.5Q657-560 640-560t-28.5 11.5Q600-537 600-520t11.5 28.5Q623-480 640-480t28.5-11.5ZM640-520Zm0 280ZM120-400v-80h320v80H120Zm0-320v-80h480v80H120Zm324 160H120v-80h360q-14 17-22.5 37T444-560Z"/></svg>
      Overzicht
    </button>
    <div class="toolbar-dropdown" id="dropdown-overview">
      <form id="overview-volunteers">
        <select class="overview-names" name="volunteerId">
          <% data.volunteers.forEach(volunteer => { %>
            <option value="<%= volunteer.id %>"><%= helper.capitalizeFirstLetter(volunteer.name) %></option>
          <% }) %>
        </select>
      </form>
    </div>
  </div>

  <div class="toolbar-item">
    <button class="toolbar-btn" data-target="dropdown-volunteer">
      <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M720-400v-120H600v-80h120v-120h80v120h120v80H800v120h-80ZM247-527q-47-47-47-113t47-113q47-47 113-47t113 47q47 47 47 113t-47 113q-47 47-113 47t-113-47ZM40-160v-112q0-34 17.5-62.5T104-378q62-31 126-46.5T360-440q66 0 130 15.5T616-378q29 15 46.5 43.5T680-272v112H40Zm80-80h480v-32q0-11-5.5-20T580-306q-54-27-109-40.5T360-360q-56 0-111 13.5T140-306q-9 5-14.5 14t-5.5 20v32Zm296.5-343.5Q440-607 440-640t-23.5-56.5Q393-720 360-720t-56.5 23.5Q280-673 280-640t23.5 56.5Q327-560 360-560t56.5-23.5ZM360-640Zm0 400Z"/></svg>
      Toevoegen
    </button>
    <div class="toolbar-dropdown" id="dropdown-volunteer">
      <form onsubmit="return !window.volunteerChanged || confirm('Let op: wijzigingen in de agenda zullen hierbij verloren gaan! Toch doorgaan?')" id="add-volunteer" action="/dashboard/add" method="POST">
        <input name="newVolunteer" type="text" placeholder="Voer naam in...">
          <button type="submit" class="toolbar-btn-submit" id="add-volunteer-btn">Opslaan</button>
      </form>
    </div>
  </div>

  <div class="toolbar-item">
    <button class="toolbar-btn" data-target="dropdown-delete">
      <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M640-520v-80h240v80H640Zm-393-7q-47-47-47-113t47-113q47-47 113-47t113 47q47 47 47 113t-47 113q-47 47-113 47t-113-47ZM40-160v-112q0-34 17.5-62.5T104-378q62-31 126-46.5T360-440q66 0 130 15.5T616-378q29 15 46.5 43.5T680-272v112H40Zm80-80h480v-32q0-11-5.5-20T580-306q-54-27-109-40.5T360-360q-56 0-111 13.5T140-306q-9 5-14.5 14t-5.5 20v32Zm296.5-343.5Q440-607 440-640t-23.5-56.5Q393-720 360-720t-56.5 23.5Q280-673 280-640t23.5 56.5Q327-560 360-560t56.5-23.5ZM360-640Zm0 400Z"/></svg>
      Verwijderen
    </button>
    <div class="toolbar-dropdown" id="dropdown-delete">
      <form onsubmit="return !window.volunteerChanged || confirm('Let op: wijzigingen in de agenda zullen hierbij verloren gaan! Toch doorgaan?')" id="delete-volunteer" action="/dashboard/delete" method="POST">
        <select class="remove-name" name="volunteerId">
          <option value="">-- Selecteer naam --</option>
          <% data.volunteers.forEach(volunteer => { %>
            <option value="<%= volunteer.id %>"><%= helper.capitalizeFirstLetter(volunteer.name) %></option>
          <% }) %>
        </select>

          <button type="submit" class="toolbar-btn-submit" id="delete-volunteer-btn">Verwijder</button>
        </div>

      </form>
    </div>
  </div>

</div>