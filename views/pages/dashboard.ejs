<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../css/reset.css">
    <link rel="stylesheet" href="../css/variables.css">
    <link rel="stylesheet" href="../css/global.css">
    <link rel="stylesheet" href="../css/pages/dashboard.css">
    <link rel="stylesheet" href="../css/navbar.css">
    <link rel="stylesheet" href="../css/print-agenda.css">
    <title>Corveerooster</title>
    <script src="../js/datepicker.js"></script>
  </head>

  <body>

    <!-- NAVIGATION PARTIAL -->
    <%- include ('../partials/navbar.ejs'); %>
    
    <!-- HEADER -->
    <header class="page-content">
      <div class="page-header">
        <p class="page-label">Corvee dienst</p>
      </div>
      <h1 class="page-title"><%- data.currentMonthName %></h1>
    </header>
    
    <div class="date-picker"><input type="date" id="datepicker" onchange="onDateChanged(event);"></div>

    <!-- Send selected names to the database after submit -->
    <form id="dashboard-form" action="/dashboard/save" method="POST">

    <!-- MAIN -->
    <main class="weeks-grid">
      
      <!-- Create a table for each week -->
      <% data.schedules.forEach((schedule, index) => { %>
      
        <div class="week-block">
          <h2 class="week-title">
            Week <%= data.weekNumbers[index] %>
          </h2>
          <div class="table-wrapper">

            <table class="table-agenda">
              <colgroup>
                <col class="col-datum">
                <col class="col-dagdeel">
                <col class="col-naam">
              </colgroup>

              <thead>
                <tr><th>Datum</th><th>Dagdeel</th><th>Naam</th></tr>
              </thead>

              <tbody>

                <!-- Create rows for each day - Extra span-elements are used for the printed version -->
                <% schedule.forEach((day, index) => { %>
                  
                <!-- Morning rows -->
                  <tr>
                    <td class="td-dag" rowspan="2"><%= helper.getNameOfDay(day.date) %><span class="datum"><%= helper.formatDate(day.date) %></span></td>
                    <td><span class="badge badge-ochtend">Ochtend</span><span class="dagdeel-print">Ochtend</span></td>
                    <td class="td-naam">
                      <select name="<%= helper.toLocalDateString(day.date) %>[morning]" id="volunteer-select-<%= index %>-morning" class="select-name">
                        <option value="">-- Selecteer vrijwilliger --</option>
                        <% data.volunteers.forEach(volunteer => { %>
                          <option value="<%= volunteer.id %>" <%= day.morning && day.morning.id === volunteer.id ? 'selected' : '' %>>
                            <%= volunteer.name %>
                          </option>
                        <% }) %>
                      </select>
                    </td>
                  </tr>

                  <!-- Afternoon rows -->
                  <tr>
                    <td><span class="badge badge-middag">Middag</span><span class="dagdeel-print">Middag</span></td>
                    <td class="td-naam td-naam-middag">
                      <select name="<%= helper.toLocalDateString(day.date) %>[afternoon]" id="volunteer-select-<%= index %>-afternoon" class="select-name">
                        <option value="">-- Selecteer vrijwilliger --</option>
                        <% data.volunteers.forEach(volunteer => { %>
                          <option value="<%= volunteer.id %>" <%= day.afternoon && day.afternoon.id === volunteer.id ? 'selected' : '' %>>
                            <%= volunteer.name %>
                          </option>
                        <% }) %>
                      </select>
                    </td>
                  </tr>
                <% }) %>

              </tbody>
            </table>
          </div> <!-- table-wrapper -->
        </div> <!-- week-block -->
      <% }) %>
    </main>
        
    </form>
    <!-- Submit button -->      
    <div class="btn-container">
      <button form="dashboard-form" class="btn-submit-name" type="submit">Opslaan</button>
    </div>
  </body>
</html>
